{
    "version": "3.5.9",
    "description": "A unified analytics engine for large-scale data processing.",
    "homepage": "https://spark.apache.org/",
    "license": "Apache-2.0",
    "url": "https://dlcdn.apache.org/spark/spark-3.5.9/spark-3.5.9-bin-hadoop3.tgz",
    "hash": "sha512:66097faf48b12f8673dc13256a44d731c27c86a5831cd8ca930c6fd9dd9bdf31d40593095e959461351d55da1a8e3ad5ed95e0b4b51bea87ca3989ab002ea8ce",
    "extract_dir": "spark-3.5.9-bin-hadoop3",
    "bin": [
        [
            "spark3-shell.cmd",
            "spark3-shell"
        ],
        [
            "spark3-submit.cmd",
            "spark3-submit"
        ],
        [
            "pyspark3.cmd",
            "pyspark3"
        ]
    ],
    "pre_install": [
        "Set-Content -Path $dir\\pyspark3.cmd -Encoding ASCII -Value '@echo off', '', \"set SPARK_HOME=$dir\", \"set PYSPARK_DRIVER_PYTHON=python312.exe\", \"set PYSPARK_PYTHON=python312.exe\", \"set JAVA_HOME=%USERPROFILE%\\scoop\\apps\\corretto17-jdk\\current\", \"$dir\\bin\\pyspark.cmd %*\"",
        "Set-Content -Path $dir\\spark3-shell.cmd -Encoding ASCII -Value '@echo off', '', \"set SPARK_HOME=$dir\", \"set JAVA_HOME=%USERPROFILE%\\scoop\\apps\\corretto17-jdk\\current\", \"$dir\\bin\\spark-shell.cmd %*\"",
        "Set-Content -Path $dir\\spark3-submit.cmd -Encoding ASCII -Value '@echo off', '', \"set SPARK_HOME=$dir\", \"set JAVA_HOME=%USERPROFILE%\\scoop\\apps\\corretto17-jdk\\current\", \"$dir\\bin\\spark-submit.cmd %*\""
    ],
    "depends": [
        "java/corretto17-jdk",
        "versions/python312"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/apache/spark/tags?per_page=100",
        "jsonpath": "$..name",
        "regex": "\"v(3\\.[\\d.]+)\""
    },
    "autoupdate": {
        "url": "https://dlcdn.apache.org/spark/spark-$version/spark-$version-bin-hadoop3.tgz",
        "hash": {
            "url": "$url.sha512",
            "regex": "$basename: ([A-F0-9\\s]+)$"
        },
        "extract_dir": "spark-$version-bin-hadoop3"
    }
}
